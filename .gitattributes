# Default to LF for text files across the repo
* text=auto eol=lf

# Windows scripts should keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts should keep LF
*.sh text eol=lf

# Common binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary

# Changelogs: the fork OWNS each package's CHANGELOG.md — Changesets writes the
# fork's release entries there (`## x.y.z` format). Upstream's Keep-a-Changelog
# history (`## [x.y.z] - date`) is archived once in CHANGELOG.upstream.md.
# merge=ours keeps the fork's CHANGELOG.md across upstream syncs so it never
# re-bloats — the old `merge=union` accumulated upstream's full history (400KB+),
# which broke changesets/action release-body extraction (whole-file dump > the
# 125000-char GitHub Release cap → 422). The .upstream.md archives stay union
# (harmless append). Fork-wide notes still live in FORK-CHANGELOG.md.
# The `ours` driver is registered by scripts/setup-merge-drivers.sh.
packages/*/CHANGELOG.md merge=ours
*CHANGELOG.upstream.md merge=union

# Model registries: generated from LIVE provider API fetches (OpenRouter, NVIDIA NIM,
# …) at generation time, so upstream's snapshot and the fork's never match → every
# sync would hard-conflict. merge=ours keeps the fork's committed snapshot on merge.
# The fork refreshes deliberately via `npm --prefix packages/ai run refresh-models`
# (decoupled from `build`, so builds no longer dirty the tree). The `ours` driver is
# registered by scripts/setup-merge-drivers.sh (run once per clone).
packages/ai/src/models.generated.ts merge=ours
packages/ai/src/image-models.generated.ts merge=ours
