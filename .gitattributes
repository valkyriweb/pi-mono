# Default to LF for text files across the repo
* text=auto eol=lf

# Windows scripts should keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts should keep LF
*.sh text eol=lf

# Common binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary

# Changelogs: auto-union on merge/rebase so upstream syncs never hard-conflict.
# Package CHANGELOGs are upstream-owned (see FORK-CHANGELOG.md); union is a safety
# net for stray edits. The fork keeps its own notes in FORK-CHANGELOG.md.
*CHANGELOG.md merge=union
