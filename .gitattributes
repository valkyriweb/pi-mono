# Default to LF for text files across the repo
* text=auto eol=lf

# Windows scripts should keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts should keep LF
*.sh text eol=lf

# Common binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary

# Changelogs: auto-union on merge/rebase so upstream syncs never hard-conflict.
# FORK-CHANGELOG.md (and any stray *CHANGELOG.md) auto-union so syncs never
# hard-conflict. Package CHANGELOG.md files are now fork-owned stubs that point
# at FORK-CHANGELOG.md + the archived upstream history — merge=ours keeps the
# stub across upstream syncs so they never re-append their full changelog (the
# old merge=union grew coding-agent's to 400KB+ and broke release-body
# extraction; see docs/adr/0002). Upstream's history is frozen once in
# CHANGELOG.upstream.md (union — harmless append if a sync ever touches it).
*CHANGELOG.md merge=union
packages/*/CHANGELOG.md merge=ours
*CHANGELOG.upstream.md merge=union

# Model registries: generated from LIVE provider API fetches (OpenRouter, NVIDIA NIM,
# …) at generation time, so upstream's snapshot and the fork's never match → every
# sync would hard-conflict. merge=ours keeps the fork's committed snapshot on merge.
# The fork refreshes deliberately via `npm --prefix packages/ai run refresh-models`
# (decoupled from `build`, so builds no longer dirty the tree). The `ours` driver is
# registered by scripts/setup-merge-drivers.sh (run once per clone).
packages/ai/src/models.generated.ts merge=ours
packages/ai/src/image-models.generated.ts merge=ours
