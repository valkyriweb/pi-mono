#!/usr/bin/env bash
# install-mini-pi — idempotent installer for pi-mono-fork release tarballs.
#
# Pulls a published GitHub release from valkyriweb/pi-mono, extracts to
# ~/.local/share/pi/<tag>/, and atomically swings ~/.local/bin/pi at it.
# Designed for the Mac Mini openclaw node but works on any darwin/linux box.
#
# Usage:
#   install-mini-pi                  # install latest fork release
#   install-mini-pi v0.74.0-valk.2   # install a specific tag
#   PI_REPO=other/fork install-mini-pi v1.2.3
#
# Requires: curl, tar, mkdir, ln. gh is optional (used only for tag
# resolution when $PI_TAG is omitted; falls back to the GitHub REST API).
# Idempotent: re-running with the same tag is a no-op past the existing
# extracted tree; the symlink is replaced atomically every call.
set -euo pipefail

PI_REPO="${PI_REPO:-valkyriweb/pi-mono}"
PI_TAG="${1:-}"
PI_PREFIX="${PI_PREFIX:-$HOME/.local}"
PI_SHARE="$PI_PREFIX/share/pi"
PI_BIN="$PI_PREFIX/bin/pi"

log() { printf '[install-mini-pi] %s\n' "$*"; }
die() { printf '[install-mini-pi] error: %s\n' "$*" >&2; exit 1; }

command -v curl >/dev/null || die "curl not found in PATH"
command -v tar >/dev/null  || die "tar not found in PATH"

# Resolve tag — default to latest non-prerelease on the fork.
if [ -z "$PI_TAG" ]; then
  if command -v gh >/dev/null 2>&1; then
    PI_TAG="$(gh release list -R "$PI_REPO" --limit 20 --json tagName,isLatest \
      --jq 'map(select(.isLatest))[0].tagName // empty')"
  else
    PI_TAG="$(curl -fsSL "https://api.github.com/repos/$PI_REPO/releases/latest" \
      | sed -n 's/.*"tag_name": *"\([^"]*\)".*/\1/p' | head -1)"
  fi
  [ -n "$PI_TAG" ] || die "no latest release found on $PI_REPO"
  log "resolved latest tag: $PI_TAG"
fi

# Detect platform → asset name.
os="$(uname -s)"; arch="$(uname -m)"
case "$os/$arch" in
  Darwin/arm64)      ASSET="pi-darwin-arm64.tar.gz" ;;
  Darwin/x86_64)     ASSET="pi-darwin-x64.tar.gz" ;;
  Linux/x86_64)      ASSET="pi-linux-x64.tar.gz" ;;
  Linux/aarch64)     ASSET="pi-linux-arm64.tar.gz" ;;
  *) die "unsupported platform: $os/$arch" ;;
esac

DEST="$PI_SHARE/$PI_TAG"
BIN="$DEST/pi"

# Idempotency: if the destination binary already exists, reuse it.
if [ -x "$BIN" ]; then
  log "tag $PI_TAG already extracted at $DEST (reusing)"
else
  log "downloading $ASSET from $PI_REPO@$PI_TAG"
  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT
  url="https://github.com/$PI_REPO/releases/download/$PI_TAG/$ASSET"
  curl -fsSL --retry 3 --retry-delay 2 -o "$tmp/$ASSET" "$url" \
    || die "download failed: $url"
  [ -s "$tmp/$ASSET" ] || die "asset $ASSET empty or missing at $url"

  mkdir -p "$DEST"
  # Tarballs ship with a leading pi/ directory; strip it so $DEST/pi is the binary.
  tar -xzf "$tmp/$ASSET" --strip-components=1 -C "$DEST"
  [ -x "$BIN" ] || die "extracted tree missing executable at $BIN"
  log "extracted to $DEST"
fi

# Atomic symlink swing: write a sibling symlink, then rename over the target.
mkdir -p "$(dirname "$PI_BIN")"
tmp_link="$PI_BIN.tmp.$$"
ln -sfn "$BIN" "$tmp_link"
mv -f "$tmp_link" "$PI_BIN"
log "symlinked $PI_BIN -> $BIN"

# Verify.
if ! "$PI_BIN" --version >/dev/null 2>&1; then
  die "pi --version failed after install"
fi
"$PI_BIN" --version | sed 's/^/[install-mini-pi] pi --version: /'

# PATH hint — only print if PI_BIN isn't reachable as `pi` already.
if ! command -v pi >/dev/null 2>&1 || [ "$(command -v pi)" != "$PI_BIN" ]; then
  log "note: add \"$(dirname "$PI_BIN")\" to PATH (e.g. in ~/.zshrc) if not already present"
fi
